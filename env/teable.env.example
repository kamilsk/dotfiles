# Teable runtime configuration.
# Copy to `teable.env` and fill in the secrets. `teable.env` is gitignored.

# Pin images for reproducible local installs. Use `latest` only for intentional rolling upgrades.
TEABLE_IMAGE_TAG=release.2026-05-07T09-04-09Z.1611
POSTGRES_VERSION=15.4
REDIS_VERSION=7.2.4

# Time zone shared by app + db (use IANA names, e.g. Europe/Moscow, Asia/Yekaterinburg).
TIMEZONE=UTC

# Where Teable, Postgres and Redis keep their on-disk state.
# Keep this outside the dotfiles repo so `git clean` and repo moves cannot remove data.
TEABLE_APP_DATA=${HOME}/.local/share/teable/app
TEABLE_DB_DATA=${HOME}/.local/share/teable/db
TEABLE_CACHE_DATA=${HOME}/.local/share/teable/cache

# Host bindings — keep on loopback for a personal install.
TEABLE_BIND_HOST=127.0.0.1
TEABLE_PORT=3000
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_HOST_PORT=42345

# Secrets — replace with strong hex/alphanumeric values before first start.
# Example generator: `openssl rand -hex 32`
SECRET_KEY=change_me_secret_key

# Postgres — service-side hostname is the container name on the teable network.
POSTGRES_HOST=teable-db
POSTGRES_PORT=5432
POSTGRES_DB=teable
POSTGRES_USER=teable
POSTGRES_PASSWORD=change_me_postgres

# Redis
REDIS_HOST=teable-cache
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change_me_redis

# App — PUBLIC_ORIGIN must match the URL you use to reach Teable in the browser
# (no trailing slash). Wrong value breaks uploads, image rendering and OAuth.
PUBLIC_ORIGIN=http://127.0.0.1:3000
PRISMA_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
PUBLIC_DATABASE_PROXY=127.0.0.1:42345

BACKEND_STORAGE_PROVIDER=local
BACKEND_CACHE_PROVIDER=redis
BACKEND_CACHE_REDIS_URI=redis://default:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Long-running transactions (bulk updates, big imports). Uncomment if needed.
#PRISMA_TRANSACTION_TIMEOUT=60000
#PRISMA_TRANSACTION_MAX_WAIT=5000

# Outgoing mail is configured in the Teable Admin Panel in current releases.
# Legacy BACKEND_MAIL_* environment variables are intentionally omitted.
