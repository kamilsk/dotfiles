#!/usr/bin/env bash

set -o nounset
set -o pipefail

case "${1-branch}" in
    branch)
        git symbolic-ref --short HEAD
    ;;
    remote)
        upstream="$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null)"
        remote="$(echo ${upstream} | awk -F'/' '{print $1}')"
        if [ "${remote}" == '@{u}' ]; then
            remote="$(git remote | grep origin | head -1)"
        fi
        if [ -z "${remote}" ]; then
            remote="$(git remote | head -1)"
        fi
        if [ -z "${remote}" ]; then
            (>&2 echo no remote found, see '`git remote`')
            exit 1
        fi
        echo $remote
    ;;
    release)
        latest=$(git describe --tags)
        if [[ $? > 0 ]]; then
            (>&2 echo no have any release)
            exit 1
        fi
        if [[ $latest =~ -[0-9]+-gc[a-z0-9]{6}$ ]]; then
            latest=$(echo $latest | rev | cut -d - -f3- | rev)
        fi
        if [[ $latest =~ - ]]; then
            echo $latest | sed 's/-/ /' | awk '{print $1" ["$2"]"}'
        else
            echo $latest
        fi
    ;;
    *)
        (>&2 echo use branch or remote as an argument)
        exit 1
    ;;
esac
