#!/usr/bin/env bash

set -o nounset
set -o pipefail

case "${1:-}" in
   git)
      git config --unset --global alias.m
      git config --unset --global alias.mm
      git config --unset --global alias.mmm
      git config --unset alias.flow
      git config --unset alias.pub
   ;;
   *)
      echo no rules
      exit 1
   ;;
esac

echo done
exit 0
