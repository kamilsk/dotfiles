#!/usr/bin/env bash

set -o nounset
set -o pipefail

echo 'mode: count' > c.out

pkgs=$(go list ./... | grep -v vendor | grep -v examples)

for pkg in $pkgs; do
    report="coverage_${pkg##*/}.out"
    go test -covermode count -coverprofile "${report}" $@ "${pkg}"
    if [ -f "${report}" ]; then
        sed '1d' "${report}" >> c.out
        rm -f "${report}"
    fi
done

go tool cover -func c.out | grep 'total:' | awk '{print $1 " " $3}'

exit 0
