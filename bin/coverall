#!/usr/bin/env bash

set -o nounset
set -o pipefail

echo 'mode: count' > c.out

pkgs=$(go list ./... | grep -v vendor | grep -v examples)
buff=''

for pkg in $pkgs; do
    report="coverage_${pkg##*/}.out"
    buff=${buff}$'\n'$(go test -covermode count -coverprofile "${report}" $@ "${pkg}")
    if [ -f "${report}" ]; then
        sed '1d' "${report}" >> c.out
        rm -f "${report}"
    fi
done

echo "${buff}" | sed 's/ of statements//' | sed 's/coverage://' | sed 's/\[no test files\]/0.0%/' | sed -E 's/[0-9.]+s//' | column -t | sort -r
go tool cover -func c.out | grep 'total:' | awk '{print $1 " " $3}'

exit 0
