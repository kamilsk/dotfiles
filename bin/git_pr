#!/usr/bin/env bash

set -o nounset
set -o pipefail

url=$(grep 'remote:.*http' | awk '{print $2}')

decision=''
case "${1:-}" in
    -y)
        decision='y'
    ;;
    -n)
        decision='n'
    ;;
esac

if [ -n "${url}" ]; then
    if [ -z "${decision}" ]; then
        read -p "Do you need to open the pull request at ${url}: " decision </dev/tty
    fi
    case "$(echo "${decision}" | awk '{print tolower($0)}')" in
        y|yes|yep)
            open "${url}"
        ;;
        n|no|nope)
            echo 👌
        ;;
    esac
fi

exit 0
