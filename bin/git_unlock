#!/usr/bin/env bash

set -o nounset
set -o pipefail

remote=${1:-origin}
sentinel=no_push

if ! git remote | grep -qx "${remote}"; then
  (echo >&2 "remote '${remote}' not found")
  exit 1
fi

# only drop the pushurl we set ourselves, never a user-defined one
if [ "$(git config --get "remote.${remote}.pushurl" || true)" != "${sentinel}" ]; then
  echo "push to '${remote}' is not locked"
  exit 0
fi

git config --unset "remote.${remote}.pushurl"
echo "push to '${remote}' is unlocked"
