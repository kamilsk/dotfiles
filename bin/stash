#!/usr/bin/env bash

# Required features:
# - [ ] multiple stashes: stash -id xyz echo scripting; stash -id xyz apply|pop
# - [ ] renaming: flush -> pop; repeat -> apply; dry -> show
# - [ ] new command: list, clear
# - [ ] pipe building: stash cat file | stash -pipe grep text | stash -pipe wc -l
#   - check stdin to automate the process?

set -o nounset
set -o pipefail

if [ ! -f "${HOME}"/.stash ]; then
    touch "${HOME}"/.stash
    chmod +x "${HOME}"/.stash
fi

case "${1:-}" in
    drop)
        > "${HOME}"/.stash
    ;;
    dry)
        cat "${HOME}"/.stash
    ;;
    flush)
        "${HOME}"/.stash
        cat > "${HOME}"/.stash << EOL
#!/usr/bin/env bash
set -o nounset
set -o pipefail
set -o xtrace

EOL
    ;;
    repeat)
        "${HOME}"/.stash
    ;;
    *)
        cmd="$@"
        eval $cmd
        code=$?
        if [ $code -eq 0 ]; then
            echo $cmd >> "${HOME}"/.stash
        fi
        exit $code
    ;;
esac

exit 0
