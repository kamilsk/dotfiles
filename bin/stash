#!/usr/bin/env bash

set -o nounset
set -o pipefail

if [ ! -f "${HOME}"/.stash ]; then
    touch "${HOME}"/.stash
    chmod +x "${HOME}"/.stash
fi

if [ "${1:-}" = 'repeat' ]; then
    "${HOME}"/.stash
    exit 0
elif [ "${1:-}" = 'flush' ]; then
    "${HOME}"/.stash
    cat > "${HOME}"/.stash << EOL
#!/usr/bin/env bash
set -o xtrace
set -o nounset
set -o pipefail

EOL
    exit 0
fi

cmd="$@"

if eval $cmd; then
    echo $cmd >> "${HOME}"/.stash
fi
