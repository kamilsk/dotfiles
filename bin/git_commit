#!/usr/bin/env bash

set -o nounset
set -o pipefail

case "${1-}" in
amend)
  git commit --amend --no-edit
  ;;
at)
  timestamp=$(date -j -v"${2-}" +"%Y-%m-%dT%H:%M:%SZ")
  GIT_COMMITTER_DATE="${timestamp}" git commit --date="${timestamp}" -m "${*:3}"
  ;;
cmm)
  message="${*:2}"
  git commit -m "${message}"
  ;;
undo)
  git reset --soft HEAD^"${2-1}"
  ;;
*)
  (echo >&2 unknown command)
  exit 1
  ;;
esac
