#!/usr/bin/env bash

set -o nounset
set -o pipefail

source=${1}
package=${source}

package=${package/%.git}
package=${package/#https:\/\/}
package=${package/#*@}

# use `declare -A map` in Bash 4 instead
package=${package/stash.msk.avito.ru:7999/go.avito.ru}

package=${package/:/\/}

set -o xtrace

mkdir -p "${GOPATH}/${package}"
git clone ${source} "${GOPATH}/${package}"
